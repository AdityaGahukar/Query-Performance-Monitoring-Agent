# =============================================================================
# POV-4: Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# All keys are required unless marked OPTIONAL.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="POV-4 Query Performance Monitoring Agent"
APP_VERSION="0.1.0"
ENVIRONMENT="development"          # development | staging | production

# -----------------------------------------------------------------------------
# Snowflake Connection
# POV-4 service account requires MONITOR privilege on target warehouses.
# -----------------------------------------------------------------------------
SNOWFLAKE_ACCOUNT="your_account.region"      # e.g. xy12345.us-east-1
SNOWFLAKE_USER="pov4_service_user"
SNOWFLAKE_PASSWORD="your_secure_password"
SNOWFLAKE_WAREHOUSE="POV4_WH"               # Warehouse POV-4 uses for its own queries
SNOWFLAKE_DATABASE="POV4_DB"               # Database for POV-4 internal tables
SNOWFLAKE_SCHEMA="POV4_SCHEMA"             # Schema for POV-4 internal tables
SNOWFLAKE_ROLE="POV4_ROLE"

# -----------------------------------------------------------------------------
# Google Gemini API
# Used exclusively by the Performance Analysis Agent (Phase 5).
# -----------------------------------------------------------------------------
GEMINI_API_KEY="your_gemini_api_key"
GEMINI_MODEL_NAME="gemini-3.5-flash"         # OPTIONAL - default: gemini-3.5-flash
GEMINI_REQUEST_TIMEOUT_SECONDS=60          # OPTIONAL - default: 60
GEMINI_MAX_RETRIES=3                        # OPTIONAL - default: 3

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL="INFO"                            # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT="json"                           # json | text  (use 'text' for local dev)

# -----------------------------------------------------------------------------
# Scheduler (APScheduler polling intervals)
# Frequencies aligned with docs/collection-strategy.md §2
# -----------------------------------------------------------------------------
SCHEDULER_QUERY_HISTORY_INTERVAL_MINUTES=5      # OPTIONAL - default: 5
SCHEDULER_WAREHOUSE_LOAD_INTERVAL_MINUTES=15    # OPTIONAL - default: 15
SCHEDULER_METERING_INTERVAL_MINUTES=60          # OPTIONAL - default: 60
SCHEDULER_QUERY_ATTRIBUTION_INTERVAL_MINUTES=60 # OPTIONAL - default: 60

# -----------------------------------------------------------------------------
# Storage (Snowflake internal tables)
# POV-4 persists all findings to Snowflake — no external DB required.
# -----------------------------------------------------------------------------
STORAGE_FINDINGS_TABLE="POV4_PERFORMANCE_FINDINGS"  # OPTIONAL - default as shown
STORAGE_WATERMARKS_TABLE="POV4_WATERMARKS"          # OPTIONAL - default as shown
STORAGE_DLQ_TABLE="POV4_DLQ"                        # OPTIONAL - default as shown
